server {
    listen 8443 ssl;
    http2 on;
    server_name __DOMAIN__;

    ssl_certificate     /etc/letsencrypt/live/__DOMAIN__/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/__DOMAIN__/privkey.pem;

    gzip on;
    gzip_types text/css application/javascript application/json image/svg+xml;
    gzip_min_length 1024;

    location = /__URL_PREFIX__ { return 301 /__URL_PREFIX__/; }

    location /__URL_PREFIX__/api/ {
        proxy_pass http://server:3000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /__URL_PREFIX__/ {
        alias /usr/share/nginx/html/;
        try_files $uri $uri/ /__URL_PREFIX__/index.html;
        sub_filter '<head>' '<head><base href="/__URL_PREFIX__/">';
        sub_filter_once on;
        sub_filter_types text/html;
    }

    location / { return 404; }
}
