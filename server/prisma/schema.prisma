generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model campaigns {
  id        Int         @id @default(autoincrement())
  source_id Int         @unique
  name      String
  chapters  chapters[]
  locations locations[]
  notes     notes[]
}

model chapters {
  id                 Int                  @id @default(autoincrement())
  campaign_id        Int
  code               String
  title              String
  menu_order         Int
  campaign           campaigns            @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  chapter_locations  chapter_locations[]

  @@unique([campaign_id, code])
  @@index([campaign_id])
}

model chapter_locations {
  chapter_id   Int
  location_dn  Int
  sort_order   Int     @default(0)
  chapter      chapters @relation(fields: [chapter_id], references: [id], onDelete: Cascade)

  @@id([chapter_id, location_dn])
  @@index([location_dn])
}

model locations {
  id             Int        @id @default(autoincrement())
  campaign_id    Int
  display_number Int
  name           String     @default("")
  campaign       campaigns  @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  verses         verses[]

  @@unique([campaign_id, display_number])
  @@index([campaign_id])
}

model verses {
  id             Int       @id @default(autoincrement())
  location_id    Int
  display_number Int
  location       locations @relation(fields: [location_id], references: [id], onDelete: Cascade)
  options        options[]
  notes          notes[]

  @@unique([location_id, display_number])
  @@index([location_id])
}

model options {
  id                  Int       @id @default(autoincrement())
  verse_id            Int
  position            Int
  type                String
  text                String    @default("")
  target_type         String?
  target_verse_dn     Int?
  target_location_dn  Int?
  requirement         String?
  result              String?
  hidden              String?
  once                Boolean   @default(false)
  condition_group     String?
  conditional_targets Json?
  children            Json?
  verse               verses    @relation(fields: [verse_id], references: [id], onDelete: Cascade)
  progress            progress?

  @@unique([verse_id, position])
  @@index([verse_id])
}

model progress {
  id         Int      @id @default(autoincrement())
  option_id  Int      @unique
  status     String   @default("visited")
  visited_at DateTime @default(now()) @db.Timestamptz
  visited_by BigInt?
  option     options  @relation(fields: [option_id], references: [id], onDelete: Cascade)

  @@index([option_id])
}

model notes {
  id          Int       @id @default(autoincrement())
  campaign_id Int
  type        String
  body        String
  verse_id    Int?
  path        Json?
  created_at  DateTime  @default(now()) @db.Timestamptz
  campaign    campaigns @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  verse       verses?   @relation(fields: [verse_id], references: [id], onDelete: Cascade)

  @@index([campaign_id, created_at(sort: Desc)])
  @@index([verse_id])
  @@index([campaign_id, type, created_at(sort: Desc)])
}

model users {
  telegram_id BigInt   @id
  username    String?
  role        String   @default("player")
  created_at  DateTime @default(now()) @db.Timestamptz
}
